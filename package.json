{
  "name": "hepr",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./three": {
      "types": "./dist/three/three/index.d.ts",
      "import": "./dist/three/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:three": "vite build --mode three-lib && tsc -p tsconfig.three.json",
