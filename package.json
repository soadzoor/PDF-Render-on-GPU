    "preview": "vite preview",
    "examples:generate": "node --max-old-space-size=12288 --experimental-strip-types scripts/generate-example-assets.ts"
  },
  "peerDependencies": {
    "three": "0.183.0"
  },
  "dependencies": {
    "jszip": "3.10.1",
    "pdfjs-dist": "5.4.624"
  },
  "devDependencies": {
    "@types/three": "0.183.0",
    "three": "0.183.0",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
